{
  "name": "UserMediaEntry",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "media_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "watched",
        "planned",
        "dropped",
        null
      ]
    },
    "rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "review": {
      "type": "string"
    },
    "spoiler_flag": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_id",
    "media_id"
  ]
}