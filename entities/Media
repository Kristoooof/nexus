{
  "name": "Media",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "movie",
        "series",
        "book",
        "game",
        "manga",
        "manhwa"
      ]
    },
    "cover_image": {
      "type": "string"
    },
    "cover_image_thumb": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "release_year": {
      "type": "integer"
    },
    "creators": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "genres": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sub_genres": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trigger_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pacing": {
      "type": "string",
      "enum": [
        "slow_burn",
        "balanced",
        "fast_paced",
        null
      ]
    },
    "tone": {
      "type": "string",
      "enum": [
        "dark",
        "lighthearted",
        "bittersweet",
        "intense",
        "whimsical",
        "gritty",
        "hopeful",
        null
      ]
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "duration_minutes": {
      "type": "integer"
    },
    "episode_count": {
      "type": "integer"
    },
    "page_count": {
      "type": "integer"
    },
    "external_ids": {
      "type": "object",
      "properties": {
        "tmdb": {
          "type": "string"
        },
        "igdb": {
          "type": "string"
        },
        "google_books": {
          "type": "string"
        },
        "anilist": {
          "type": "string"
        }
      }
    },
    "avg_rating": {
      "type": "number",
      "default": 0
    },
    "rating_count": {
      "type": "integer",
      "default": 0
    },
    "featured": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "title",
    "type"
  ]
}